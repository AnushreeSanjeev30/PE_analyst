# ============================================================
# APPLICATION
# ============================================================

APP_NAME=PE-Analyst
APP_ENV=development
DEBUG=true

HOST=127.0.0.1
PORT=8000


# ============================================================
# LOGGING
# ============================================================

LOG_LEVEL=INFO


# ============================================================
# OPENAI
# ============================================================

OPENAI_API_KEY=your_openai_api_key_here

OPENAI_MODEL=gpt-5-mini

OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# ============================================================
# DATABASE
# ============================================================

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pe_analyst


# ============================================================
# VECTOR STORE
# ============================================================

VECTOR_STORE_PROVIDER=pgvector

VECTOR_COLLECTION_NAME=pe_analyst_documents


# ============================================================
# DOCUMENT STORAGE
# ============================================================

UPLOAD_DIR=data/uploads

PROCESSED_DATA_DIR=data/processed

MAX_UPLOAD_SIZE_MB=50


# ============================================================
# DOCUMENT PROCESSING
# ============================================================

DOCUMENT_CHUNK_SIZE=1200

DOCUMENT_CHUNK_OVERLAP=200


# ============================================================
# RETRIEVAL
# ============================================================

RETRIEVAL_TOP_K=10

RERANK_TOP_K=5


# ============================================================
# AGENT WORKFLOW
# ============================================================

MAX_AGENT_ITERATIONS=10

ENABLE_AGENT_TRACING=true


# ============================================================
# EXTERNAL RESEARCH
# ============================================================

SEC_USER_AGENT=PE-Analyst your_email@example.com


# ============================================================
# LBO DEFAULTS
# ============================================================

DEFAULT_HOLDING_PERIOD_YEARS=5

DEFAULT_TAX_RATE=0.25

DEFAULT_INTEREST_RATE=0.08